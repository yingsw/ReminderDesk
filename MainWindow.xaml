<Window x:Class="ReminderDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务提醒助手"
        Height="700"
        Width="950"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        AllowsTransparency="False">

    <Window.Resources>
        <Style x:Key="CardShadow" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#20000000" BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Path Data="M12,2 L22,12 L12,22 L2,12 Z M12,6 L18,12 L12,18 L6,12 Z"
                      Fill="{DynamicResource AccentBrush}" Width="32" Height="32"
                      Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="任务提醒助手" Style="{DynamicResource MainTitleStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 皮肤切换按钮 -->
            <Button x:Name="SkinButton" Content="切换皮肤"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="SkinButton_Click"
                    Style="{DynamicResource SkinButtonStyle}"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：添加任务 -->
            <Border Grid.Column="0" Style="{DynamicResource CardStyle}" Margin="0,0,12,0" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{DynamicResource ScrollViewerStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Path Data="M12,4 L12,20 M4,12 L20,12"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                                  Width="20" Height="20" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="添加新任务" Style="{DynamicResource TitleStyle}"/>
                        </StackPanel>

                        <!-- 任务描述 -->
                        <TextBlock Text="任务描述" Style="{DynamicResource LabelStyle}"/>
                        <TextBox x:Name="DescriptionTextBox"
                                 Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource InputStyle}"
                                 Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,16"/>

                        <!-- 优先级 -->
                        <TextBlock Text="优先级" Style="{DynamicResource LabelStyle}"/>
                        <ComboBox x:Name="PriorityComboBox" SelectedIndex="{Binding NewPriority}"
                                  Style="{DynamicResource ComboBoxStyle}" Margin="0,0,0,16">
                            <ComboBoxItem Content="低"/>
                            <ComboBoxItem Content="中"/>
                            <ComboBoxItem Content="高"/>
                            <ComboBoxItem Content="紧急"/>
                        </ComboBox>

                        <!-- 完成日期时间 -->
                        <TextBlock Text="完成时间" Style="{DynamicResource LabelStyle}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" x:Name="DueDatePicker" SelectedDate="{Binding NewDueDate}"
                                        Style="{DynamicResource DatePickerStyle}" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="时间:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" FontSize="13"/>
                            <ComboBox Grid.Column="2" x:Name="DueTimeComboBox" SelectedIndex="{Binding NewDueTimeIndex}"
                                      Style="{DynamicResource ComboBoxStyle}">
                                <ComboBoxItem Content="09:00"/>
                                <ComboBoxItem Content="10:00"/>
                                <ComboBoxItem Content="11:00"/>
                                <ComboBoxItem Content="12:00"/>
                                <ComboBoxItem Content="13:00"/>
                                <ComboBoxItem Content="14:00"/>
                                <ComboBoxItem Content="15:00"/>
                                <ComboBoxItem Content="16:00"/>
                                <ComboBoxItem Content="17:00"/>
                                <ComboBoxItem Content="18:00"/>
                                <ComboBoxItem Content="19:00"/>
                                <ComboBoxItem Content="20:00"/>
                                <ComboBoxItem Content="21:00"/>
                                <ComboBoxItem Content="22:00"/>
                            </ComboBox>
                        </Grid>

                        <!-- 提醒类型选择 -->
                        <TextBlock Text="提醒方式" Style="{DynamicResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="BuiltInRadio" Content="内置函数" IsChecked="{Binding IsBuiltInReminder}"
                                         Style="{DynamicResource RadioButtonStyle}"
                                         Margin="0,0,20,0" Checked="ReminderType_Changed"/>
                            <RadioButton x:Name="CustomRadio" Content="自定义函数" IsChecked="{Binding IsCustomReminder}"
                                         Style="{DynamicResource RadioButtonStyle}"
                                         Checked="ReminderType_Changed"/>
                        </StackPanel>

                        <!-- 内置提醒选项 -->
                        <StackPanel x:Name="BuiltInPanel">
                            <ComboBox x:Name="ReminderFunctionComboBox"
                                      SelectedIndex="{Binding NewReminderFunctionIndex}"
                                      Style="{DynamicResource ComboBoxStyle}" Margin="0,0,0,8">
                                <ComboBoxItem Content="完成时间提醒"/>
                                <ComboBoxItem Content="提前5分钟"/>
                                <ComboBoxItem Content="提前10分钟"/>
                                <ComboBoxItem Content="提前15分钟"/>
                                <ComboBoxItem Content="提前20分钟"/>
                                <ComboBoxItem Content="提前30分钟"/>
                                <ComboBoxItem Content="提前45分钟"/>
                                <ComboBoxItem Content="提前1小时"/>
                                <ComboBoxItem Content="提前2小时"/>
                                <ComboBoxItem Content="提前3小时"/>
                                <ComboBoxItem Content="提前6小时"/>
                                <ComboBoxItem Content="提前12小时"/>
                                <ComboBoxItem Content="提前1天"/>
                                <ComboBoxItem Content="提前2天"/>
                                <ComboBoxItem Content="提前3天"/>
                                <ComboBoxItem Content="提前1周"/>
                                <ComboBoxItem Content="当天早上7点"/>
                                <ComboBoxItem Content="当天早上8点"/>
                                <ComboBoxItem Content="当天早上9点"/>
                                <ComboBoxItem Content="当天早上10点"/>
                                <ComboBoxItem Content="当天中午12点"/>
                                <ComboBoxItem Content="当天中午13点"/>
                                <ComboBoxItem Content="当天傍晚17点"/>
                                <ComboBoxItem Content="当天傍晚18点"/>
                                <ComboBoxItem Content="当天傍晚19点"/>
                                <ComboBoxItem Content="当天晚上20点"/>
                                <ComboBoxItem Content="当天晚上21点"/>
                                <ComboBoxItem Content="第二天早上8点"/>
                                <ComboBoxItem Content="第二天早上9点"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- 自定义函数输入 -->
                        <StackPanel x:Name="CustomPanel" Visibility="Collapsed">
                            <TextBlock Text="自定义函数表达式" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox x:Name="CustomFunctionTextBox"
                                     Text="{Binding CustomFunctionExpression, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}" Margin="0,0,0,8"/>
                            <Border Background="#F0F4FF" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="可用表达式：" FontWeight="Medium"/><LineBreak/>
                                    <Run Text="• DueTime-1h / DueTime+30m"/><LineBreak/>
                                    <Run Text="• Date+9h / Date+18h"/><LineBreak/>
                                    <Run Text="• Tomorrow+9h"/><LineBreak/>
                                    <Run Text="• NextWorkday+9h"/><LineBreak/>
                                    <Run Text="• NextMonday+9h"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- 提醒时间预览 -->
                        <Border Background="{DynamicResource AccentGradientBrush}" CornerRadius="12"
                                Padding="16" Margin="0,12,0,20">
                            <StackPanel>
                                <TextBlock Text="提醒时间预览" FontSize="12" FontWeight="Medium"
                                           Foreground="#80FFFFFF"/>
                                <TextBlock x:Name="ReminderPreviewText" Text="{Binding ReminderPreview}"
                                           FontSize="16" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- 添加按钮 -->
                        <Button Content="添加任务" Command="{Binding AddTaskCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{DynamicResource AccentGradientBrush}" CornerRadius="12">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Path Data="M12,4 L12,20 M4,12 L20,12"
                                                  Stroke="White" StrokeThickness="2.5"
                                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="添加任务" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            <Setter TargetName="border" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#6366F1" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右侧：任务列表 -->
            <Border Grid.Column="1" Style="{DynamicResource CardStyle}" Margin="12,0,0,0" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 统计栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Style="{DynamicResource StatCardStyle}" Margin="0,0,12,0"
                                Background="#EDE9FE" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2 A10,10 0 1,0 12,22 A10,10 0 1,0 12,2 M12,6 A6,6 0 1,1 12,18 A6,6 0 1,1 12,6"
                                      Fill="{DynamicResource AccentBrush}" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="待办 " Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding PendingCount}"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="20"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource StatCardStyle}"
                                Background="#D1FAE5" BorderBrush="#10B981" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2 A10,10 0 1,0 12,22 A10,10 0 1,0 12,2 M8,12 L10,14 L16,8"
                                      Fill="#10B981" Width="18" Height="18"
                                      Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="已完成 " Foreground="#10B981" FontSize="13"/>
                                <TextBlock Text="{Binding CompletedCount}" Foreground="#10B981"
                                           FontWeight="Bold" FontSize="20"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 任务列表 -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Reminders}" SelectedItem="{Binding SelectedReminder}"
                             Style="{DynamicResource ListBoxStyle}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{DynamicResource TaskCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 优先级指示 -->
                                        <Border Grid.Column="0" Width="14" Height="14" CornerRadius="7"
                                                Margin="0,0,14,0" VerticalAlignment="Center"
                                                BorderThickness="0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PriorityColor}"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- 任务内容 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Description}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Path Data="M12,2 L12,22 M2,12 L22,12"
                                                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                                      Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <Run Text="{Binding DueTime, StringFormat='MM/dd HH:mm'}"/>
                                                </TextBlock>
                                                <TextBlock Text=" | " Foreground="#DDD" FontSize="12"/>
                                                <TextBlock Text="{Binding RemainingText}" FontSize="12" FontWeight="Medium"
                                                           Foreground="#F44336"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 完成勾选 -->
                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsCompleted}"
                                                  Style="{DynamicResource CheckBoxStyle}"
                                                  VerticalAlignment="Center" Margin="12,0" Click="CompleteCheckBox_Click"/>

                                        <!-- 删除按钮 -->
                                        <Button Grid.Column="3" Content="删除" Click="DeleteButton_Click" Tag="{Binding Id}"
                                                Style="{DynamicResource DeleteButtonStyle}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="#FEE2E2" CornerRadius="8" Padding="12,8">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path Data="M6,6 L18,18 M18,6 L6,18"
                                                                  Stroke="#EF4444" StrokeThickness="2"
                                                                  Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                            <TextBlock Text="删除" FontSize="12" FontWeight="Medium" Foreground="#EF4444"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#FECACA"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>