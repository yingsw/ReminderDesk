<Window x:Class="ReminderDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ReminderDesk.ViewModel"
        xmlns:models="clr-namespace:ReminderDesk.Models"
        xmlns:converters="clr-namespace:ReminderDesk.Converters"
        mc:Ignorable="d"
        Title="ReminderDesk - 任务提醒助手"
        Height="700"
        Width="950"
        MinHeight="600"
        MinWidth="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI"
        FontSize="14"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    
    <Window.Resources>
        <converters:PriorityColorConverter x:Key="PriorityColorConverter"/>
        <converters:PriorityBgColorConverter x:Key="PriorityBgColorConverter"/>
        <converters:CompletedTextConverter x:Key="CompletedTextConverter"/>
    </Window.Resources>

    <!-- Window Chrome -->
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CaptionHeight="0"
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <!-- Main Container -->
    <Grid>
        <!-- Glass Background -->
        <Border CornerRadius="16"
                Margin="10"
                Background="#F0FFFFFF"
                BorderBrush="#40FFFFFF"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#20000000"
                                  BlurRadius="30"
                                  ShadowDepth="0"
                                  Opacity="0.5"/>
            </Border.Effect>
        </Border>

        <!-- Content -->
        <Border CornerRadius="16" Margin="10" Background="Transparent">
            <Grid>
                <!-- Title Bar -->
                <Border Height="50" VerticalAlignment="Top" Background="#10FFFFFF" CornerRadius="16,16,0,0">
                    <Grid Margin="20,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text=" ReminderDesk"
                                      FontSize="22"
                                      FontWeight="SemiBold"
                                      Foreground="#1a1a1a"/>
                            <TextBlock Text=" · 任务提醒助手"
                                      FontSize="14"
                                      Foreground="#666"
                                      Margin="5,5,0,0"
                                      VerticalAlignment="Bottom"/>
                        </StackPanel>

                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="40" Height="40" Click="Minimize_Click" Background="Transparent" BorderThickness="0">
                                <Path Data="M0,6 L16,6" Stroke="#666" StrokeThickness="2" Margin="8"/>
                            </Button>
                            <Button Width="40" Height="40" Click="Maximize_Click" Background="Transparent" BorderThickness="0">
                                <Path Data="M2,2 L14,2 L14,14 L2,14 Z" Stroke="#666" StrokeThickness="2" Margin="8"/>
                            </Button>
                            <Button Width="40" Height="40" Click="Close_Click" Background="Transparent" BorderThickness="0">
                                <Path Data="M2,2 L14,14 M14,2 L2,14" Stroke="#E81123" StrokeThickness="2" Margin="8"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content -->
                <Grid Margin="10,60,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel - Add Task -->
                    <Border Grid.Column="0" CornerRadius="12" Background="#20FFFFFF" Margin="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="添加新任务" FontSize="18" FontWeight="SemiBold" Foreground="#1a1a1a" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="任务标题" FontSize="13" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                    Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                                    Foreground="#1a1a1a" Padding="12,10" Margin="0,0,0,15"/>

                            <TextBlock Text="任务描述" FontSize="13" Foreground="#666" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NewTaskDescription, UpdateSourceTrigger=PropertyChanged}"
                                    Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                                    Foreground="#1a1a1a" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                    Padding="12,10" Margin="0,0,0,15"/>

                            <TextBlock Text="提醒时间" FontSize="13" Foreground="#666" Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding NewTaskReminderTime}"
                                       Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                                       Padding="12,10" Margin="0,0,0,15"/>

                            <TextBlock Text="优先级" FontSize="13" Foreground="#666" Margin="0,0,0,5"/>
                            <ComboBox SelectedIndex="{Binding NewTaskPriority}"
                                     Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1"
                                     Padding="12,10" Margin="0,0,0,20">
                                <ComboBoxItem Content="低优先级"/>
                                <ComboBoxItem Content="中优先级"/>
                                <ComboBoxItem Content="高优先级"/>
                                <ComboBoxItem Content="紧急"/>
                            </ComboBox>

                            <Button Content="添加任务" Command="{Binding AddTaskCommand}"
                                   Background="#402196F3" Foreground="White" FontSize="15" FontWeight="SemiBold"
                                   BorderThickness="0" Height="45" Margin="0,10,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Right Panel - Task List -->
                    <Border Grid.Column="1" CornerRadius="12" Background="#15FFFFFF" Margin="10" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Statistics -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <Border Background="#E3F2FD" CornerRadius="8" Padding="15,10" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="待办 " Foreground="#1565C0" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding PendingCount}" Foreground="#1565C0" FontWeight="Bold" FontSize="18"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#E8F5E9" CornerRadius="8" Padding="15,10" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="已完成 " Foreground="#2E7D32" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CompletedCount}" Foreground="#2E7D32" FontWeight="Bold" FontSize="18"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="任务列表" FontSize="18" FontWeight="SemiBold" Foreground="#1a1a1a" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </StackPanel>

                            <!-- Task List -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding Reminders}" SelectedItem="{Binding SelectedReminder}"
                                    Background="Transparent" BorderThickness="0" Margin="0,0,0,15">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:ReminderItem">
                                        <Border CornerRadius="10" Background="#30FFFFFF" Margin="0,5" Padding="15"
                                               BorderBrush="#40FFFFFF" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Priority Dot -->
                                                <Ellipse Grid.Column="0" Width="12" Height="12" Margin="0,0,10,0"
                                                        Fill="{Binding Priority, Converter={StaticResource PriorityColorConverter}}"/>

                                                <!-- Task Info -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                                                              Foreground="{Binding IsCompleted, Converter={StaticResource CompletedTextConverter}}"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#666"
                                                              MaxHeight="40" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="{Binding ReminderTime, StringFormat='提醒: {0:MM/dd HH:mm}'}"
                                                                  FontSize="12" Foreground="#888"/>
                                                        <TextBlock Text=" · " FontSize="12" Foreground="#888"/>
                                                        <TextBlock Text="{Binding RemainingTimeText}" FontSize="12" Foreground="#888"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Priority Badge -->
                                                <Border Grid.Column="2" CornerRadius="6" Padding="8,4" Margin="10,0"
                                                       Background="{Binding Priority, Converter={StaticResource PriorityBgColorConverter}}">
                                                    <TextBlock Text="{Binding PriorityText}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Actions -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="完成" Command="{Binding CompleteTaskCommand}"
                                       Background="#20607D8B" Foreground="#607D8B" Width="80" Height="36" Margin="0,0,10,0"
                                       BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="删除" Command="{Binding DeleteTaskCommand}"
                                       Background="#20F44336" Foreground="#F44336" Width="80" Height="36"
                                       BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>